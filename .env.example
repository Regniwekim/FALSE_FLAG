# Backend runtime
HOST=0.0.0.0
PORT=3001
# Comma-separated allowlist for browser origins in production.
# Example: https://false-flag-frontend.onrender.com,https://your-custom-domain.com
CORS_ORIGINS=

# Frontend build-time socket endpoint
# Local: http://127.0.0.1:3001
# Render: https://false-flag-backend.onrender.com
VITE_SOCKET_URL=
