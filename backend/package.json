{
  "name": "@flagwho/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "cd .. && npm run build -w shared && cd backend && vitest run"
  },
  "dependencies": {
    "@flagwho/shared": "file:../shared",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.8.6",
    "socket.io-client": "^4.8.0",
    "tsx": "^4.19.1",
    "typescript": "^6.0.2",
    "vitest": "^2.1.8"
  }
}
